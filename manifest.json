{
  "manifest_version": 3,
  "name": "Algorithm Java Auto Formatter",
  "version": "1.3.3",
  "description": "백준, SWEA에 자바 코드 붙여넣기 시 자동으로 package 제거 및 알맞은 클래스명으로 변환합니다.",
  "icons": {
    "16": "images/logo_16.png",
    "32": "images/logo_32.png",
    "48": "images/logo_48.png",
    "128": "images/logo_128.png"
  },
  "permissions": [
    "storage" 
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/logo_16.png",
      "32": "images/logo_32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.acmicpc.net/submit/*",
        "*://swexpertacademy.com/*",
        "*://www.swexpertacademy.com/*"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "js": [
        "content/constants.js",
        "content/ui.js",
        "content/parser.js",
        "content/transform.js",
        "content/handler.js"
      ]
    }
  ]
}
