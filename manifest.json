{
  "manifest_version": 3,
  "name": "Algorithm Java Auto Formatter",
  "version": "1.3",
  "description": "백준, SWEA에 자바 코드 붙여넣기 시 자동으로 package 제거 및 알맞은 클래스명으로 변환합니다.",
  "permissions": [
    "storage" 
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.acmicpc.net/submit/*",
        "*://swexpertacademy.com/*"
      ],
      "js": [
        "content/constants.js",
        "content/ui.js",
        "content/parser.js",
        "content/transform.js",
        "content/handler.js"
      ]
    }
  ]
}
